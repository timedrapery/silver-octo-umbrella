<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OSINT Report — {{ case.name }}</title>
  <style>
    :root {
      --bg: #0f0f1a;
      --panel: #1e1e2e;
      --panel2: #2d2d3f;
      --accent: #7c6af7;
      --text: #e2e8f0;
      --muted: #9ca3af;
      --info: #6b7280;
      --low: #3b82f6;
      --medium: #f59e0b;
      --high: #ef4444;
      --critical: #dc2626;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--bg); color: var(--text); font-family: "Segoe UI", sans-serif; padding: 32px; }
    header { display: flex; justify-content: space-between; align-items: center;
             border-bottom: 2px solid var(--accent); padding-bottom: 16px; margin-bottom: 32px; }
    header h1 { font-size: 28px; color: var(--accent); }
    header .meta { text-align: right; color: var(--muted); font-size: 13px; }
    h2 { color: var(--accent); font-size: 18px; margin: 24px 0 12px; }
    .summary-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 16px; margin-bottom: 24px; }
    .stat-card { background: var(--panel2); border-radius: 8px; padding: 16px; text-align: center; }
    .stat-card .num { font-size: 32px; font-weight: bold; color: var(--accent); }
    .stat-card .label { font-size: 12px; color: var(--muted); margin-top: 4px; }
    table { width: 100%; border-collapse: collapse; margin-bottom: 24px; }
    th { background: var(--panel2); color: var(--muted); text-align: left; padding: 10px 12px; font-size: 12px; text-transform: uppercase; }
    td { padding: 10px 12px; border-bottom: 1px solid #333; font-size: 13px; vertical-align: top; }
    tr:hover td { background: var(--panel2); }
    .badge { display: inline-block; padding: 2px 8px; border-radius: 12px; font-size: 11px; font-weight: bold; color: white; }
    .badge-INFO { background: var(--info); }
    .badge-LOW { background: var(--low); }
    .badge-MEDIUM { background: var(--medium); }
    .badge-HIGH { background: var(--high); }
    .badge-CRITICAL { background: var(--critical); }
    .section { background: var(--panel); border-radius: 8px; padding: 20px; margin-bottom: 24px; }
    footer { text-align: center; color: var(--muted); font-size: 12px; margin-top: 32px; border-top: 1px solid #333; padding-top: 16px; }
  </style>
</head>
<body>
  <header>
    <div>
      <h1>🔍 OSINT Research Platform</h1>
      <p style="color: var(--muted); margin-top: 4px;">Confidential Intelligence Report</p>
    </div>
    <div class="meta">
      <div><strong>{{ case.name }}</strong></div>
      <div>Status: {{ case.status.value }}</div>
      <div>Generated: {{ case.updated_at.strftime('%Y-%m-%d %H:%M UTC') if case.updated_at.strftime is defined else case.updated_at }}</div>
    </div>
  </header>

  <div class="section">
    <h2>Executive Summary</h2>
    {% set severity_counts = {} %}
    {% for f in case.findings %}
      {% set _ = severity_counts.update({f.severity.value: (severity_counts.get(f.severity.value, 0) + 1)}) %}
    {% endfor %}
    <div class="summary-grid">
      <div class="stat-card"><div class="num">{{ case.targets|length }}</div><div class="label">Targets</div></div>
      <div class="stat-card"><div class="num">{{ case.findings|length }}</div><div class="label">Findings</div></div>
      <div class="stat-card"><div class="num" style="color:#dc2626;">{{ severity_counts.get('CRITICAL', 0) }}</div><div class="label">Critical</div></div>
      <div class="stat-card"><div class="num" style="color:#ef4444;">{{ severity_counts.get('HIGH', 0) }}</div><div class="label">High</div></div>
      <div class="stat-card"><div class="num" style="color:#f59e0b;">{{ severity_counts.get('MEDIUM', 0) }}</div><div class="label">Medium</div></div>
      <div class="stat-card"><div class="num" style="color:#3b82f6;">{{ severity_counts.get('LOW', 0) }}</div><div class="label">Low</div></div>
    </div>
    {% if case.description %}
    <p style="color: var(--muted);">{{ case.description }}</p>
    {% endif %}
  </div>

  {% if case.targets %}
  <div class="section">
    <h2>Targets ({{ case.targets|length }})</h2>
    <table>
      <tr><th>Type</th><th>Value</th><th>Added</th></tr>
      {% for t in case.targets %}
      <tr>
        <td><span class="badge badge-INFO">{{ t.type.value }}</span></td>
        <td>{{ t.value }}</td>
        <td>{{ t.created_at }}</td>
      </tr>
      {% endfor %}
    </table>
  </div>
  {% endif %}

  <div class="section">
    <h2>Findings ({{ case.findings|length }})</h2>
    <table>
      <tr><th>Severity</th><th>Type</th><th>Title</th><th>Adapter</th><th>Description</th><th>Collected</th></tr>
      {% for f in case.findings|sort(attribute='severity.value') %}
      <tr>
        <td><span class="badge badge-{{ f.severity.value }}">{{ f.severity.value }}</span></td>
        <td>{{ f.finding_type.value }}</td>
        <td><strong>{{ f.title }}</strong></td>
        <td>{{ f.adapter_name }}</td>
        <td>{{ f.description[:120] }}{% if f.description|length > 120 %}…{% endif %}</td>
        <td>{{ f.collected_at }}</td>
      </tr>
      {% endfor %}
    </table>
  </div>

  {% if case.findings %}
  <div class="section">
    <h2>Source Citations</h2>
    <table>
      <tr><th>Finding</th><th>Source</th><th>URL</th></tr>
      {% for f in case.findings if f.source_url %}
      <tr>
        <td>{{ f.title }}</td>
        <td>{{ f.source_name }}</td>
        <td><a href="{{ f.source_url }}" style="color: var(--accent);">{{ f.source_url }}</a></td>
      </tr>
      {% endfor %}
    </table>
  </div>
  {% endif %}

  <footer>
    OSINT Research Platform — Confidential — {{ case.name }} — {{ case.id }}
  </footer>
</body>
</html>

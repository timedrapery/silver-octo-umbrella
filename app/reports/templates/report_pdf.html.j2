<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>OSINT Report — {{ case.name }}</title>
  <style>
    @media print {
      body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .no-print { display: none; }
      .page-break { page-break-before: always; }
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #ffffff; color: #1a1a2e; font-family: "Times New Roman", serif; padding: 32px; font-size: 11pt; }
    header { border-bottom: 2px solid #4a3f9f; padding-bottom: 12px; margin-bottom: 24px; }
    header h1 { font-size: 20pt; color: #4a3f9f; }
    header .meta { color: #555; font-size: 10pt; margin-top: 4px; }
    h2 { color: #4a3f9f; font-size: 14pt; margin: 20px 0 10px; border-bottom: 1px solid #ccc; padding-bottom: 4px; }
    .summary-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 8px; margin-bottom: 20px; }
    .stat-card { border: 1px solid #ccc; border-radius: 4px; padding: 10px; text-align: center; }
    .stat-card .num { font-size: 22pt; font-weight: bold; color: #4a3f9f; }
    .stat-card .label { font-size: 9pt; color: #666; }
    table { width: 100%; border-collapse: collapse; margin-bottom: 20px; font-size: 10pt; }
    th { background: #eeeeee; color: #333; text-align: left; padding: 6px 8px; border: 1px solid #ccc; }
    td { padding: 6px 8px; border: 1px solid #ddd; vertical-align: top; }
    .badge { display: inline-block; padding: 1px 6px; border-radius: 8px; font-size: 9pt; font-weight: bold; color: white; }
    .badge-INFO { background: #6b7280; }
    .badge-LOW { background: #3b82f6; }
    .badge-MEDIUM { background: #f59e0b; }
    .badge-HIGH { background: #ef4444; }
    .badge-CRITICAL { background: #dc2626; }
    footer { text-align: center; color: #888; font-size: 9pt; margin-top: 24px; border-top: 1px solid #ccc; padding-top: 10px; }
  </style>
</head>
<body>
  <header>
    <h1>OSINT Research Platform — Intelligence Report</h1>
    <div class="meta">
      Case: <strong>{{ case.name }}</strong> &nbsp;|&nbsp;
      Status: {{ case.status.value }} &nbsp;|&nbsp;
      Generated: {{ case.updated_at }}
    </div>
  </header>

  <h2>Executive Summary</h2>
  {% set severity_counts = {} %}
  {% for f in case.findings %}
    {% set _ = severity_counts.update({f.severity.value: (severity_counts.get(f.severity.value, 0) + 1)}) %}
  {% endfor %}
  <div class="summary-grid">
    <div class="stat-card"><div class="num">{{ case.targets|length }}</div><div class="label">Targets</div></div>
    <div class="stat-card"><div class="num">{{ case.findings|length }}</div><div class="label">Findings</div></div>
    <div class="stat-card"><div class="num">{{ severity_counts.get('CRITICAL', 0) }}</div><div class="label">Critical</div></div>
    <div class="stat-card"><div class="num">{{ severity_counts.get('HIGH', 0) }}</div><div class="label">High</div></div>
    <div class="stat-card"><div class="num">{{ severity_counts.get('MEDIUM', 0) }}</div><div class="label">Medium</div></div>
    <div class="stat-card"><div class="num">{{ severity_counts.get('LOW', 0) }}</div><div class="label">Low</div></div>
  </div>

  {% if case.targets %}
  <h2>Targets</h2>
  <table>
    <tr><th>Type</th><th>Value</th><th>Added</th></tr>
    {% for t in case.targets %}
    <tr>
      <td>{{ t.type.value }}</td>
      <td>{{ t.value }}</td>
      <td>{{ t.created_at }}</td>
    </tr>
    {% endfor %}
  </table>
  {% endif %}

  <h2 class="page-break">Findings</h2>
  <table>
    <tr><th>Severity</th><th>Type</th><th>Title</th><th>Adapter</th><th>Description</th></tr>
    {% for f in case.findings %}
    <tr>
      <td><span class="badge badge-{{ f.severity.value }}">{{ f.severity.value }}</span></td>
      <td>{{ f.finding_type.value }}</td>
      <td>{{ f.title }}</td>
      <td>{{ f.adapter_name }}</td>
      <td>{{ f.description[:100] }}{% if f.description|length > 100 %}…{% endif %}</td>
    </tr>
    {% endfor %}
  </table>

  <footer>
    OSINT Research Platform — Confidential — {{ case.name }} — {{ case.id }}
  </footer>
</body>
</html>
